{
  "name": "myscheme-scraper",
  "version": "1.0.0",
  "description": "Playwright scraper for myscheme.gov.in - Extracts all Indian government schemes with structured data",
  "main": "dist/scraper.js",
  "scripts": {
    "build": "tsc",
    "scrape": "ts-node src/scraper.ts",
    "scrape:fast": "ts-node src/scraper.ts --fast",
    "scrape:headless": "playwright test",
    "test": "playwright test",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "playwright",
    "scraper",
    "myscheme",
    "government",
    "india",
    "schemes"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "playwright": "^1.40.0",
    "p-limit": "^3.1.0"
  }
}
